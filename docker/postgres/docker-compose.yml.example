services:
  postgres:
    # Base de datos dedicada para n8n.
    # No publicar el puerto 5432: PostgreSQL debe quedar accesible solo desde aula-network.
    image: postgres:17
    container_name: postgres
    restart: unless-stopped
    env_file:
      - ../../env/postgres.env.example
    volumes:
      - /srv/docker/postgres/data:/var/lib/postgresql/data
    networks:
      - aula-network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U \"$${POSTGRES_USER}\" -d \"$${POSTGRES_DB}\""]
      interval: 30s
      timeout: 5s
      retries: 5

networks:
  aula-network:
    external: true
