# Plantilla de variables para n8n.
# Copiar a un archivo .env real fuera de Git antes de usar.
# No versionar claves, tokens ni contrasenas reales.

N8N_HOST=CAMBIAR_ESTE_VALOR
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_SECURE_COOKIE=false
GENERIC_TIMEZONE=Europe/Madrid
TZ=Europe/Madrid

# Conexion a PostgreSQL por red Docker aula-network.
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=CAMBIAR_ESTE_VALOR

# Clave interna de cifrado de credenciales de n8n.
# Debe ser estable y guardarse fuera del repositorio.
N8N_ENCRYPTION_KEY=CAMBIAR_ESTE_VALOR

# OAuth:
# Para Google OAuth se necesitara URL publica HTTPS o tunel/dominio valido.
# WEBHOOK_URL=https://dominio-publico.example.com/
# N8N_EDITOR_BASE_URL=https://dominio-publico.example.com/
