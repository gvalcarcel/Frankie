# Plantilla SMTP para n8n.
# Usar una cuenta tecnica del centro si esta disponible.
# No versionar contrasenas reales ni passwords de aplicacion.

N8N_EMAIL_MODE=smtp
N8N_SMTP_HOST=smtp.gmail.com
N8N_SMTP_PORT=587
N8N_SMTP_USER=usuario@example.com
N8N_SMTP_PASS=CAMBIAR_ESTE_VALOR
N8N_SMTP_SENDER=usuario@example.com
N8N_SMTP_SSL=false
